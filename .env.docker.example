# Janus Docker Compose env file.
#   cp .env.docker.example .env.docker
#   chmod 600 .env.docker
#   # then fill in below; never commit .env.docker
#
# Used only by the FOREX stack — NSE runs as systemd via ./install.sh.

# ── Required ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Forex API auth ──────────────────────────────────────────────────────
# Admin bootstrap. Leave empty to auto-generate (key written to /run/forex/admin.key
# inside the container — pull it out with `docker compose exec forex-api cat /run/forex/admin.key`).
FOREX_ADMIN_API_KEY=

# CORS allow-list, comma-separated. Set to your real frontend origin in prod.
FOREX_TRUSTED_ORIGINS=http://localhost:8445

# Host port the forex API binds to.
FOREX_API_PORT=8445

# ── LLM cascade (at least one is required) ──────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── ML model integrity ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MODEL_HMAC_SECRET=
